{
  "name": "action-crowdin-contributors",
  "version": "3.0.0",
  "private": true,
  "description": "Automate acknowledging translators and proofreaders to your open-source projects in Crowdin",
  "main": "lib/main.js",
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write '**/*.ts'",
    "format-check": "prettier --check '**/*.ts'",
    "package": "npx rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "test": "jest",
    "test-coverage": "jest --ci --reporters=jest-junit --reporters=default --coverage --coverageReporters=cobertura --coverageReporters=html",
    "all": "npm run format && npm run lint && npm run package && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrii-bodnar/action-crowdin-contributors"
  },
  "keywords": [
    "actions",
    "crowdin",
    "translations",
    "sync",
    "contributors",
    "acknowledgement",
    "table",
    "translators",
    "proofreaders",
    "open-source",
    "report",
    "crowdsourcing"
  ],
  "author": {
    "name": "Andrii Bodnar",
    "url": "https://github.com/andrii-bodnar"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.1",
    "@crowdin/crowdin-api-client": "^1.45.1",
    "axios": "^1.10.0",
    "dotenv": "^17.2.0",
    "pretty": "^2.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.9",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^20",
    "@types/pretty": "^2.0.3",
    "@typescript-eslint/parser": "^8.48.1",
    "eslint": "^9.39.1",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.2.1",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^30.2.0",
    "jest-junit": "^16.0.0",
    "js-yaml": "^4.1.1",
    "prettier": "3.7.4",
    "rollup": "^4.53.3",
    "ts-jest": "^29.4.6",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
